---
import { person as p, site } from "@/consts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Markdown from "@/components/Markdown.astro";
---

<BaseLayout
  title="Home"
  description={site.description}
  schemas={[
    {
      "@type": "WebSite",
      "@id": new URL("/#website", Astro.url.origin).href,
      url: Astro.url.href,
      name: site.name,
      description: site.description,
      author: {
        "@id": new URL("/#person", Astro.url.origin).href,
      },
    },
  ]}
>
  <!-- prettier-ignore -->
  <Markdown>
# {site.name}

Hello, World! And welcome to my corner of the internet!

I am {p.fullname} ({p.pronouns}). I am passionate about technology,
privacy and open source development. I am from Krasnoyarsk, Russia.

## Pages

- [About me](/about/)
- [My posts (blog)](/posts/)
- [My projects](/projects/)
  </Markdown>
</BaseLayout>
