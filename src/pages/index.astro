---
import type { WithContext, WebSite } from "schema-dts";
import { site, fullname, pronouns } from "@/consts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Markdown from "@/components/Markdown.astro";

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": new URL("/#website", Astro.url.origin).href,
  url: Astro.url.href,
  name: site.name,
  description: site.description,
  author: {
    "@id": new URL("/#person", Astro.url.origin).href,
  },
} satisfies WithContext<WebSite>;
---

<BaseLayout title="Home" description={site.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(website)} />
  </Fragment>
  <!-- prettier-ignore -->
  <Markdown>
# {site.name}

Hello, World! And welcome to my corner of the internet!

I am {fullname} ({pronouns}). I am passionate about technology,
privacy and open source development. I am from Krasnoyarsk, Russia.

## Pages

- [About me](/about/)
- [My posts (blog)](/posts/)
- [My projects](/projects/)
  </Markdown>
</BaseLayout>
