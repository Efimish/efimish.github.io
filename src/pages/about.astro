---
import {
  firstname,
  lastname,
  fullname,
  username,
  gender,
  pronouns,
  email,
  github,
  telegram,
  vk,
} from "@/consts";
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLD from "@/components/JsonLD.astro";
import Markdown from "@/components/Markdown.astro";
---

<BaseLayout
  title="About"
  description=`About ${fullname}, an open-source developer and thinker passionate about technology and privacy.`
>
  <Fragment slot="og">
    <meta property="og:type" content="profile" />
    <meta property="profile:first_name" content={firstname} />
    <meta property="profile:last_name" content={lastname} />
    <meta property="profile:username" content={username} />
    <meta property="profile:gender" content={gender.toLowerCase()} />
  </Fragment>
  <Fragment slot="head">
    <JsonLD
      schema={{
        "@type": "Person",
        "@id": new URL("/#person", Astro.url.origin).href,
        url: Astro.url.href,
        givenName: firstname,
        familyName: lastname,
        name: fullname,
        alternateName: username,
        gender: gender,
        email: `mailto:${email}`,
        sameAs: [github, telegram, vk],
      }}
    />
    <JsonLD
      schema={{
        "@type": "ProfilePage",
        url: Astro.url.href,
        name: "About",
        mainEntity: {
          "@id": new URL("/#person", Astro.url.origin).href,
        },
      }}
    />
  </Fragment>
  <!-- prettier-ignore -->
  <Markdown>
# About

Hello, traveler!

I am {fullname} ({pronouns}). I am passionate about technology,
privacy and open source development. I am from Krasnoyarsk, Russia.

## 🛠️ Skills

- TypeScript, Rust, Python, SQL
- Astro
- Git, Docker, PostgreSQL, Caddy
- GitHub Actions

## 📚 Education

Siberian Federal University - B.Sc. in Computer Science, 2023-2027
  </Markdown>
</BaseLayout>
