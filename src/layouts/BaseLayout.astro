---
import "@/styles/tailwind.css";

import type { Metadata } from "@/lib/types";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props extends Metadata {}
---

<!doctype html>
<html
  class="bg-neutral-100 text-lg text-neutral-900 accent-blue-500 scheme-light dark:bg-neutral-900 dark:text-neutral-100 dark:accent-blue-400 dark:scheme-dark"
  lang="en"
>
  <head>
    <BaseHead {...Astro.props} />
    <script>
      import "@/scripts/theme";
      import "@/scripts/console";
    </script>
  </head>

  <body class="mx-auto my-0 max-w-3xl p-4">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
