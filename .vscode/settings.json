{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "prettier.documentSelectors": ["**/*.astro"],
  "tinymist.fontPaths": ["src/assets/fonts"],
  "foam.files.include": [
    "src/content/posts/**/*.md",
    "public/**",
    "src/assets/**"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[astro]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
